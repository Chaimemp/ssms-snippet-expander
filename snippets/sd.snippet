<?xml version="1.0" encoding="utf-8"?>
<CodeSnippets xmlns="http://schemas.microsoft.com/VisualStudio/2005/CodeSnippet">
  <CodeSnippet Format="1.0.0">
    <Header>
      <Title>SELECT DISTINCT</Title>
      <Shortcut>sd</Shortcut>
      <Description>SELECT DISTINCT col FROM table</Description>
      <Author>Custom</Author>
      <SnippetTypes>
        <SnippetType>Expansion</SnippetType>
      </SnippetTypes>
    </Header>
    <Snippet>
      <Declarations>
        <Literal>
          <ID>Column</ID>
          <ToolTip>Column name</ToolTip>
          <Default>Column1</Default>
        </Literal>
        <Literal>
          <ID>TableName</ID>
          <ToolTip>Table name</ToolTip>
          <Default>TableName</Default>
        </Literal>
      </Declarations>
      <Code Language="SQL"><![CDATA[SELECT DISTINCT $Column$ FROM [$TableName$]$end$]]></Code>
    </Snippet>
  </CodeSnippet>
</CodeSnippets>
